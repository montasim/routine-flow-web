# RoutineFlow environment template
# Copy to .env.local for local development or set equivalent values in the
# deployment provider. Do not commit real secrets.

# Runtime
# Next.js sets NODE_ENV automatically for dev/build/start. Override only for
# scripts that run outside the normal Next runtime.
# NODE_ENV=development
LOG_LEVEL=debug

# MongoDB
# Required in production. Include the database name in the URI path.
# If omitted locally, the app falls back to local file-backed development
# storage where supported.
MONGODB_URI="mongodb+srv://USER:PASSWORD@HOST/routineflow?retryWrites=true&w=majority"

# Auth/session signing
# Required in production. Generate a long random value, for example:
# openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret

# Better Auth deployment metadata
# Required by the requirements/deployment checklist. The current app code uses
# AUTH_SECRET for signing, so keep BETTER_AUTH_SECRET in sync if your deployment
# or Better Auth runtime expects the Better Auth variable name. Google OAuth
# uses BETTER_AUTH_URL to build the exact callback URI sent to Google.
BETTER_AUTH_SECRET=replace-with-the-same-value-as-AUTH_SECRET
BETTER_AUTH_URL="http://localhost:3000"

# Email OTP delivery
# RESEND_API_KEY and OTP_FROM_EMAIL are required for production OTP email.
# In local development, missing Resend config skips email delivery and the
# deterministic OTP code is 123456.
RESEND_API_KEY=re_replace-with-resend-api-key
OTP_FROM_EMAIL="RoutineFlow <otp@example.com>"

# API security / CORS
# Use explicit origins only. Do not include mobile deep-link schemes here.
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# OAuth / mobile deep-link redirect allowlist
# Include web callback URLs and mobile app deep-link callback URLs.
ALLOWED_REDIRECT_URIS="routineflow://auth/callback,http://localhost:3000/auth/callback"

# Scheduled job authorization
# Required if calling POST /api/v1/cron. Send as:
# Authorization: Bearer $SCHEDULED_JOB_SECRET
SCHEDULED_JOB_SECRET=replace-with-a-long-random-cron-secret

# Google OAuth
# Optional locally, required when Google sign-in is enabled. Add this redirect
# URI to the Google OAuth web client. If BETTER_AUTH_URL changes, this URI must
# change to the same origin:
# http://localhost:3000/api/v1/auth/social/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Inngest
# Requirement placeholder for durable background jobs if/when /api/inngest is
# enabled. The current codebase does not read this variable yet.
INNGEST_SIGNING_KEY=
